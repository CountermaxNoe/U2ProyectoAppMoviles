<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="U2ProyectoAppMoviles.Views.SplashPage"
             Title="SplashPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#1E293B">

    <Grid RowDefinitions="*, Auto, *">

        <VerticalStackLayout Grid.Row="1"
                             HorizontalOptions="Center"
                             Spacing="16">

            <Border BackgroundColor="#EA580C"
                    StrokeShape="RoundRectangle 20"
                    Stroke="Transparent"
                    HeightRequest="88"
                    WidthRequest="88"
                    HorizontalOptions="Center">
                <Image Source="error.png"
                       HeightRequest="52"
                       WidthRequest="52"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Border>

            <Label Text="Alerta Ciudadana"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <VerticalStackLayout Grid.Row="2"
                             VerticalOptions="End"
                             Padding="0,0,0,60"
                             Spacing="12">

            <ActivityIndicator IsRunning="True"
                               Color="#EA580C"
                               HeightRequest="24"
                               WidthRequest="24"
                               HorizontalOptions="Center"/>

            <Label Text="Cargando..."
                   FontSize="12"
                   TextColor="#64748B"
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>
    </Grid>

</ContentPage>